{
    "name": "homecare/homecare",
    "description": "Medication schedule, intake, and inventory tracking for home caregivers.",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "dompdf/dompdf": "^3.1"
    },
    "require-dev": {
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "HomeCare\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HomeCare\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "migrate": "php bin/migrate.php",
        "check": [
            "@analyse",
            "@test"
        ]
    }
}
