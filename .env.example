# HomeCare Docker stack — copy to .env and adjust for your install.
# All values fall back to safe local-dev defaults if .env is absent.

# MySQL credentials (used by both the db container and the web container).
MYSQL_ROOT_PASSWORD=rootpw
MYSQL_DATABASE=homecare
MYSQL_USER=homecare
MYSQL_PASSWORD=homecare

# Timezone for PHP and the entrypoint.
TZ=America/New_York

# Host port to expose the web container on. Override if 8080 is taken.
HC_WEB_PORT=8080
